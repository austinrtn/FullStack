const ServerPath = struct {
    url: []const u8,
    path: []const u8, 
    query: ?[]const u8,
    allocator: std.mem.Allocator,

    fn get(self: *@This()) ![]const u8 {
        if(self.query) |qry| { return try std.fmt.allocPrint(self.allocator, "{s}/{s}?{s}=", .{self.url, self.path, qry}); }
        else { return try std.fmt.allocPrint(self.allocator, "{s}/{s}", .{self.url, self.path}); }
    }
};

